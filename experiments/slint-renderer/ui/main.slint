import { Button, LineEdit, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component MainWindow inherits Window {
    title: "Keiko Foundation — Slint";
    preferred-width: 720px;
    preferred-height: 480px;
    min-width: 520px;
    min-height: 360px;
    background: root.dark-mode ? #17191f : #f8faff;

    in-out property <bool> dark-mode: false;
    in-out property <string> input-text: "ready";
    in-out property <string> status-text: "Stable shell";
    out property <bool> input-has-focus: input.has-focus;
    callback focus-input();

    focus-input => {
        input.focus();
    }

    VerticalBox {
        padding: 48px;
        spacing: 16px;

        Text {
            text: "Keiko Foundation";
            font-size: 28px;
            font-weight: 700;
            color: root.dark-mode ? #f5f7ff : #17233b;
            accessible-label: "Keiko Foundation";
        }
        Text {
            text: "Slint renderer candidate";
            color: root.dark-mode ? #f5f7ff : #17233b;
        }
        Text {
            text: "Synthetic international input";
            color: root.dark-mode ? #f5f7ff : #17233b;
        }
        input := LineEdit {
            text <=> root.input-text;
            accessible-label: "Synthetic international input";
        }
        HorizontalBox {
            spacing: 12px;
            Button {
                text: "Focus checkpoint";
            }
            Button {
                text: "Native cancellation";
            }
        }
        Text {
            text: root.status-text;
            color: root.dark-mode ? #f5f7ff : #17233b;
            accessible-label: root.status-text;
        }
    }
}
