{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Keiko Foundation Tauri Evaluation",
  "version": "0.0.0",
  "identifier": "dev.oscharko.keiko.foundation.tauri-evaluation",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "capabilities": [],
      "csp": "default-src 'self'; connect-src 'none'; img-src 'self' data:; style-src 'self'; script-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Keiko Foundation — Tauri",
        "width": 720,
        "height": 480,
        "minWidth": 520,
        "minHeight": 360,
        "resizable": true,
        "visible": true,
        "url": "index.html"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png"],
    "createUpdaterArtifacts": false,
    "category": "DeveloperTool",
    "shortDescription": "Throwaway foundation host evaluation"
  }
}
